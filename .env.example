# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Plaid (sandbox | development | production)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# GoCardless / Nordigen (EU Open Banking)
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=

# Okta
OKTA_ORG_URL=
OKTA_API_TOKEN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (email notifications)
RESEND_API_KEY=

# Internal
CRON_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to 'true' to bypass external API calls and use mock data
MOCK_SERVICES=true

# Must match MOCK_SERVICES — client-side copy so the Dev Tools panel is visible
NEXT_PUBLIC_MOCK_SERVICES=true
